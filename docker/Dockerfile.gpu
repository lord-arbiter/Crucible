# Crucible GPU box — MI300X / ROCm / vLLM serving Qwen3-VL + FastAPI orchestrator
#
# AMD's modern Docker images for vLLM on Instinct GPUs ship under
# rocm/vllm-dev or vllm/vllm-openai-rocm. The legacy rocm/vllm:rocm7.2_*
# tag does NOT exist. Use one of:
#   - rocm/vllm-dev:nightly_main_20260509   (AMD-tuned, MI300X-optimised)
#   - vllm/vllm-openai-rocm:latest          (upstream vLLM ROCm image)
#
# Override at build time:
#   docker build -f docker/Dockerfile.gpu --build-arg BASE=vllm/vllm-openai-rocm:latest -t crucible:gpu .
ARG BASE=rocm/vllm-dev:nightly_main_20260509
FROM ${BASE}

ENV DEBIAN_FRONTEND=noninteractive \
    PYTHONUNBUFFERED=1 \
    PYTHONDONTWRITEBYTECODE=1 \
    \
    # AMD MI300X tuning — keep these in sync with entrypoint.sh.
    HSA_FORCE_FINE_GRAIN_PCIE=1 \
    HIP_VISIBLE_DEVICES=0 \
    VLLM_USE_V1=1 \
    VLLM_ROCM_USE_AITER=1 \
    VLLM_V1_USE_PREFILL_DECODE_ATTENTION=1 \
    SAFETENSORS_FAST_GPU=1 \
    \
    # HuggingFace download accelerator.
    HF_HUB_ENABLE_HF_TRANSFER=1 \
    \
    # Crucible orchestrator config.
    CRUCIBLE_VLM_ENDPOINT=http://localhost:8001/v1 \
    CRUCIBLE_VLM_MODEL=Qwen/Qwen3-VL-32B-Instruct \
    CRUCIBLE_VLM_SERVED_NAME=crucible-vlm \
    CRUCIBLE_API_HOST=0.0.0.0 \
    CRUCIBLE_API_PORT=8000

WORKDIR /workspace/crucible

# System packages: AV1 decoders for LeRobot v3 video, plus init/tooling.
RUN apt-get update && apt-get install -y --no-install-recommends \
        ffmpeg \
        libavcodec-extra \
        libdav1d-dev \
        libaom-dev \
        git \
        curl \
        ca-certificates \
        tini \
    && rm -rf /var/lib/apt/lists/*

# IMPORTANT: do NOT reinstall torch — the base image's ROCm-tuned torch wheel
# is hand-built for MI300X. We pin transformers >= 4.57 (Qwen3-VL native
# support) and add xgrammar for reliable JSON-schema guided decoding.
RUN pip install --no-cache-dir --no-deps \
        "vllm>=0.16.0" \
    && pip install --no-cache-dir \
        "transformers>=4.57.0" \
        "xgrammar>=0.1.18" \
        "openai>=1.50" \
        "litellm>=1.50,<2" \
        "huggingface_hub[hf_transfer]>=0.26" \
        "datasets>=3.1" \
        "pyarrow>=15" \
        "pandas>=2.2" \
        "pillow>=10.4" \
        "av>=12.3" \
        "fastapi>=0.115" \
        "uvicorn[standard]>=0.30" \
        "sse-starlette>=2.1" \
        "pydantic>=2.8" \
        "tenacity>=9.0"

COPY src/ ./src/
COPY scripts/ ./scripts/
COPY data/ ./data/

EXPOSE 8000 8001

COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["tini", "--", "/entrypoint.sh"]
