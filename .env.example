# vLLM endpoint serving Qwen3-VL on the MI300X (or H100 fallback) droplet.
# When running locally for dev, point this at a local vllm serve instance.
CRUCIBLE_VLM_ENDPOINT=http://localhost:8001/v1
CRUCIBLE_VLM_MODEL=Qwen/Qwen3-VL-32B-Instruct
CRUCIBLE_VLM_API_KEY=EMPTY

# Public URL of the FastAPI orchestrator. The Gradio Space talks to this.
CRUCIBLE_API_BASE=http://localhost:8000
CRUCIBLE_API_HOST=0.0.0.0
CRUCIBLE_API_PORT=8000

# HuggingFace token used for push-to-hub. Provide via the Space's secrets;
# never commit a real token here.
HF_TOKEN=

# Crucible runtime tunables (all optional — defaults in src/config.py).
CRUCIBLE_MAX_EPISODES=25
CRUCIBLE_FRAMES_PER_EPISODE=16
CRUCIBLE_IMAGE_MAX_DIM=768
CRUCIBLE_MAX_MODEL_LEN=65536
CRUCIBLE_KEEP_THRESHOLD=7.5
CRUCIBLE_POLISH_THRESHOLD=5.0

# vLLM serve tunables (used by docker/entrypoint.sh).
VLLM_PORT=8001
VLLM_MAX_LEN=65536
VLLM_GPU_UTIL=0.85
VLLM_MAX_IMAGES_PER_PROMPT=16
VLLM_MAX_NUM_SEQS=16
VLLM_DTYPE=bfloat16

# AMD-specific tuning (already set in the Dockerfile; export here for non-Docker runs).
HSA_FORCE_FINE_GRAIN_PCIE=1
HIP_VISIBLE_DEVICES=0
VLLM_USE_V1=1
VLLM_ROCM_USE_AITER=1
HF_HUB_ENABLE_HF_TRANSFER=1
