# =====================================================================
# Crucible — environment variables
#
# Copy this to .env (which is gitignored) or export directly. The three
# CRUCIBLE_VLM_* values are mandatory; everything else has sensible
# defaults in src/config.py.
# =====================================================================

# ---------------------------------------------------------------------
# Backend selection (required) — pick ONE block below and uncomment it
# ---------------------------------------------------------------------

# Self-hosted vLLM (Docker on your own GPU box)
CRUCIBLE_VLM_ENDPOINT=http://localhost:8001/v1
CRUCIBLE_VLM_MODEL=Qwen/Qwen3-VL-8B-Instruct
CRUCIBLE_VLM_API_KEY=EMPTY

# Hyperbolic (cheapest hosted Qwen3-VL)
# CRUCIBLE_VLM_ENDPOINT=https://api.hyperbolic.xyz/v1
# CRUCIBLE_VLM_MODEL=Qwen/Qwen3-VL-72B-Instruct
# CRUCIBLE_VLM_API_KEY=

# Together AI
# CRUCIBLE_VLM_ENDPOINT=https://api.together.xyz/v1
# CRUCIBLE_VLM_MODEL=Qwen/Qwen3-VL-32B-Instruct
# CRUCIBLE_VLM_API_KEY=

# DashScope (Alibaba intl) — official Qwen API
# CRUCIBLE_VLM_ENDPOINT=https://dashscope-intl.aliyuncs.com/compatible-mode/v1
# CRUCIBLE_VLM_MODEL=qwen3-vl-plus
# CRUCIBLE_VLM_API_KEY=

# Local Mac via mlx-vlm — laptop dev path
# CRUCIBLE_VLM_ENDPOINT=http://localhost:8001/v1
# CRUCIBLE_VLM_MODEL=mlx-community/Qwen3-VL-2B-Instruct-4bit
# CRUCIBLE_VLM_API_KEY=EMPTY

# ---------------------------------------------------------------------
# Crucible orchestrator
# ---------------------------------------------------------------------
CRUCIBLE_API_BASE=http://localhost:8000
CRUCIBLE_API_HOST=0.0.0.0
CRUCIBLE_API_PORT=8000

# ---------------------------------------------------------------------
# Pipeline tunables (all optional)
# ---------------------------------------------------------------------
CRUCIBLE_MAX_EPISODES=25
CRUCIBLE_FRAMES_PER_EPISODE=16
CRUCIBLE_IMAGE_MAX_DIM=768
CRUCIBLE_MAX_MODEL_LEN=65536
CRUCIBLE_KEEP_THRESHOLD=7.5
CRUCIBLE_POLISH_THRESHOLD=5.0
CRUCIBLE_REQUEST_RETRIES=2
CRUCIBLE_TIMEOUT_PER_EPISODE_S=90

# ---------------------------------------------------------------------
# HuggingFace Hub
# ---------------------------------------------------------------------
# Read access for streaming datasets (avoids rate limits). Optional but
# recommended. Get one at https://huggingface.co/settings/tokens.
HF_TOKEN=

# Crucible's push-to-Hub flow accepts a write-scoped token via the
# Gradio UI or the /push_filtered API; do NOT commit a real token here.

# ---------------------------------------------------------------------
# vLLM serve tunables (used by docker/entrypoint.{sh,cuda.sh})
# ---------------------------------------------------------------------
VLLM_PORT=8001
VLLM_MAX_LEN=32768
VLLM_GPU_UTIL=0.90
VLLM_MAX_IMAGES_PER_PROMPT=16
VLLM_MAX_NUM_SEQS=16
VLLM_DTYPE=bfloat16
VLLM_TENSOR_PARALLEL=1

# ---------------------------------------------------------------------
# AMD-specific (used by docker/entrypoint.sh on MI300X)
# ---------------------------------------------------------------------
HSA_FORCE_FINE_GRAIN_PCIE=1
HIP_VISIBLE_DEVICES=0
VLLM_USE_V1=1
VLLM_ROCM_USE_AITER=1
HF_HUB_ENABLE_HF_TRANSFER=1
