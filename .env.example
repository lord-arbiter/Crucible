# vLLM endpoint serving Qwen3-VL on the MI300X (or H100 fallback) droplet.
# When running locally for dev, point this at a local vllm serve instance.
CRUCIBLE_VLM_ENDPOINT=http://localhost:8001/v1
CRUCIBLE_VLM_MODEL=Qwen/Qwen3-VL-32B-Instruct

# Public URL of the FastAPI orchestrator. The Gradio Space talks to this.
CRUCIBLE_API_BASE=http://localhost:8000

# HuggingFace token used for push-to-hub. Provide via the Space's secrets;
# never commit a real token here.
HF_TOKEN=

# Optional: cap on episodes per /score_dataset request.
CRUCIBLE_MAX_EPISODES=25
